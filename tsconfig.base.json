{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@concierge/types": ["packages/types/src/index.ts"],
      "@concierge/types/*": ["packages/types/src/*"],
      "@concierge/ui-shared": ["packages/ui-shared/src/index.ts"]
    }
  }
}
