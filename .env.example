# ============================================================
# CONCIERGE - Variables d'environnement
# Copier ce fichier vers .env et adapter
# ============================================================

# --- ENVIRONNEMENT ---
NODE_ENV=development

# --- MONGODB ---
MONGO_URI=mongodb://localhost:27017/concierge
MONGO_TEST_URI=mongodb://localhost:27017/concierge_test

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=change_me_super_secret_in_prod
JWT_REFRESH_SECRET=change_me_refresh_secret_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- PORTS SERVICES ---
PORT_GATEWAY=3000
PORT_AUTH=3001
PORT_CONTENT=3002
PORT_ORDERS=3003
PORT_SURVEY=3004
PORT_NOTIFICATION=3005
PORT_ANALYTICS=3006

# --- URLS PUBLIQUES (pour les frontends) ---
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3005

# --- FRONTENDS PORTS DEV ---
PORT_LOBBY=4100
PORT_SMILEY=4200
PORT_ADMIN=4300
PORT_RECEPTION=4400

# --- CORS ---
CORS_ORIGINS=http://localhost:4100,http://localhost:4200,http://localhost:4300,http://localhost:4400

# --- MULTI-TENANT ---
DEFAULT_TENANT_ID=hotel-royal-lyon
